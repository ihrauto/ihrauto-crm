APP_NAME="IHRAUTO CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# ASSET_URL=https://cdn.ihrauto.ch  # Set to CDN URL in production for static assets

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ihrauto_crm
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# SESSION
# Set SESSION_ENCRYPT=true in production
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Set FILESYSTEM_DISK=public and PUBLIC_FILESYSTEM_DRIVER=s3 in production
QUEUE_CONNECTION=database
# Set QUEUE_CONNECTION=redis in production

CACHE_STORE=database
# Set CACHE_STORE=redis in production
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# EMAIL CONFIGURATION (Resend)
# ============================================
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@ihrauto.ch"
MAIL_FROM_NAME="${APP_NAME}"

# Alternative: SMTP Configuration (uncomment to use)
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null

# ============================================
# GOOGLE OAUTH (required for social login)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ============================================
# AWS (optional — for file storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# PUBLIC FILE STORAGE (S3-compatible for production uploads)
# ============================================
PUBLIC_FILESYSTEM_DRIVER=local
PUBLIC_FILESYSTEM_KEY=
PUBLIC_FILESYSTEM_SECRET=
PUBLIC_FILESYSTEM_REGION="${AWS_DEFAULT_REGION}"
PUBLIC_FILESYSTEM_BUCKET=
PUBLIC_FILESYSTEM_URL=
PUBLIC_FILESYSTEM_ENDPOINT=
PUBLIC_FILESYSTEM_ROOT=public
PUBLIC_FILESYSTEM_USE_PATH_STYLE_ENDPOINT="${AWS_USE_PATH_STYLE_ENDPOINT}"

# ============================================
# BACKUP STORAGE (keep temp files local, archive destination can be S3)
# ============================================
BACKUP_DESTINATION_DISK=backups
BACKUP_FILESYSTEM_DRIVER=local
BACKUP_FILESYSTEM_KEY=
BACKUP_FILESYSTEM_SECRET=
BACKUP_FILESYSTEM_REGION="${AWS_DEFAULT_REGION}"
BACKUP_FILESYSTEM_BUCKET=
BACKUP_FILESYSTEM_URL=
BACKUP_FILESYSTEM_ENDPOINT=
BACKUP_FILESYSTEM_ROOT=backups
BACKUP_FILESYSTEM_USE_PATH_STYLE_ENDPOINT="${AWS_USE_PATH_STYLE_ENDPOINT}"

VITE_APP_NAME="${APP_NAME}"

# ============================================
# MONITORING & ALERTS
# ============================================
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.2
LOG_SLACK_WEBHOOK_URL=

# ============================================
# CORS (comma-separated allowed origins for API)
# ============================================
CORS_ALLOWED_ORIGINS="${APP_URL}"

# ============================================
# BACKUP NOTIFICATIONS
# ============================================
BACKUP_NOTIFICATION_EMAIL=

# ============================================
# SUPPORT CONTACTS
# ============================================
CRM_SUPPORT_EMAIL=
CRM_SUPPORT_PHONE=

# ============================================
# AUTO-LOGIN (local development only)
# ============================================
AUTO_LOGIN_ENABLED=false

# ============================================
# OWNER SUPERADMIN (for seeder only)
# ============================================
SUPERADMIN_EMAIL=info@ihrauto.ch
SUPERADMIN_NAME="Platform Owner"
SUPERADMIN_PASSWORD=
