APP_NAME="IHRAUTO CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# ASSET_URL=https://cdn.ihrauto.ch  # Set to CDN URL in production for static assets

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ihrauto_crm
DB_USERNAME=root
DB_PASSWORD=
# Scalability H-9: log any PG statement slower than N ms to the server log.
# Empty = disabled. Recommended production value: 500.
DB_SLOW_QUERY_LOG_MS=
# Application name sent to PG — useful for `pg_stat_activity` filtering
# when multiple services share the same database.
DB_APP_NAME=ihrauto-crm

# ============================================
# SESSION
# Set SESSION_ENCRYPT=true in production.
# Scalability B-1: production MUST use `redis`. The database driver
# becomes a lock-contention hotspot at 200 tenants (every request
# writes a row). Local dev can keep `database` or switch to `file`.
# ============================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Set FILESYSTEM_DISK=public and PUBLIC_FILESYSTEM_DRIVER=s3 in production
QUEUE_CONNECTION=database
# Set QUEUE_CONNECTION=redis in production

CACHE_STORE=database
# Set CACHE_STORE=redis in production
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
# Bug review OPS-10: REDIS_PASSWORD=null is acceptable ONLY in local dev.
# Production AppServiceProvider refuses to boot when Redis is used as a
# cache / session / queue backend AND this is null or empty. Set a strong
# random string in production and configure the Redis server with
# --requirepass to match.
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# EMAIL CONFIGURATION (Resend)
# ============================================
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@ihrauto.ch"
MAIL_FROM_NAME="${APP_NAME}"

# Alternative: SMTP Configuration (uncomment to use)
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null

# ============================================
# GOOGLE OAUTH (required for social login)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ============================================
# AWS (optional — for file storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# PUBLIC FILE STORAGE (S3-compatible for production uploads)
# ============================================
PUBLIC_FILESYSTEM_DRIVER=local
PUBLIC_FILESYSTEM_KEY=
PUBLIC_FILESYSTEM_SECRET=
PUBLIC_FILESYSTEM_REGION="${AWS_DEFAULT_REGION}"
PUBLIC_FILESYSTEM_BUCKET=
PUBLIC_FILESYSTEM_URL=
PUBLIC_FILESYSTEM_ENDPOINT=
PUBLIC_FILESYSTEM_ROOT=public
PUBLIC_FILESYSTEM_USE_PATH_STYLE_ENDPOINT="${AWS_USE_PATH_STYLE_ENDPOINT}"

# ============================================
# BACKUP STORAGE (keep temp files local, archive destination can be S3)
# ============================================
BACKUP_DESTINATION_DISK=backups
BACKUP_FILESYSTEM_DRIVER=local
BACKUP_FILESYSTEM_KEY=
BACKUP_FILESYSTEM_SECRET=
BACKUP_FILESYSTEM_REGION="${AWS_DEFAULT_REGION}"
BACKUP_FILESYSTEM_BUCKET=
BACKUP_FILESYSTEM_URL=
BACKUP_FILESYSTEM_ENDPOINT=
BACKUP_FILESYSTEM_ROOT=backups
BACKUP_FILESYSTEM_USE_PATH_STYLE_ENDPOINT="${AWS_USE_PATH_STYLE_ENDPOINT}"

VITE_APP_NAME="${APP_NAME}"

# ============================================
# MONITORING & ALERTS
# ============================================
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.2
LOG_SLACK_WEBHOOK_URL=

# ============================================
# CORS (comma-separated allowed origins for API)
# ============================================
CORS_ALLOWED_ORIGINS="${APP_URL}"

# ============================================
# TRUSTED PROXIES (security review M-9)
# ============================================
# Comma-separated list of IPs / CIDR blocks whose X-Forwarded-* headers
# Laravel should honour. Set this to your edge's egress ranges in
# production (Render, Cloudflare, a self-hosted LB) so clients cannot
# spoof X-Forwarded-For (defeats rate-limit IP keying) or
# X-Forwarded-Proto (defeats HTTPS enforcement).
#
# Leave unset or `*` for legacy trust-all behaviour (acceptable when the
# container is only reachable through a single trusted proxy).
TRUSTED_PROXIES=

# ============================================
# BACKUP NOTIFICATIONS
# ============================================
BACKUP_NOTIFICATION_EMAIL=

# ============================================
# SUPPORT CONTACTS
# ============================================
CRM_SUPPORT_EMAIL=
CRM_SUPPORT_PHONE=

# ============================================
# AUTO-LOGIN (local development only)
# ============================================
AUTO_LOGIN_ENABLED=false

# ============================================
# OWNER SUPERADMIN (for seeder only)
# ============================================
SUPERADMIN_EMAIL=info@ihrauto.ch
SUPERADMIN_NAME="Platform Owner"
SUPERADMIN_PASSWORD=

# ============================================
# STRIPE BILLING (Cashier)
# ============================================
# Test keys live at https://dashboard.stripe.com/test/apikeys
# Webhook secret comes from `stripe listen --forward-to localhost:8000/stripe/webhook`
# Price IDs come from Stripe Dashboard → Products → each plan
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_TRIAL_DAYS=14
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=de_CH
