# =============================================================================
# IHRAUTO CRM — .env.production.example
# =============================================================================
# Copy to `.env` before running `docker compose up`. Fill in every value
# marked with  !!!FILL!!!  — nothing here is safe to leave blank.
# =============================================================================

APP_KEY=                                # generate with `php artisan key:generate --show`
APP_URL=https://crm.example.ch          # your public host

# --- Database ---
POSTGRES_DB=ihrauto
POSTGRES_USER=ihrauto
POSTGRES_PASSWORD=!!!FILL!!!            # strong random — stored in container env + pgbouncer

# --- Redis ---
REDIS_PASSWORD=!!!FILL!!!               # any non-empty value unless your network is trusted

# --- Mail (Resend recommended) ---
RESEND_API_KEY=!!!FILL!!!               # https://resend.com
MAIL_FROM_ADDRESS=noreply@example.ch
MAIL_FROM_NAME="IHRAUTO CRM"

# --- S3-compatible backup storage ---
S3_KEY=!!!FILL!!!
S3_SECRET=!!!FILL!!!
S3_REGION=eu-central-1
S3_BUCKET=ihrauto-crm-backups

BACKUP_NOTIFICATION_EMAIL=ops@example.ch

# --- Initial super admin (seeded once on first boot) ---
SUPERADMIN_EMAIL=admin@example.ch
SUPERADMIN_PASSWORD=!!!FILL!!!          # strong random; CHANGE immediately after first login
